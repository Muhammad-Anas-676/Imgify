{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/dashboard",      "destination": "/dashboard.html"       },
    { "source": "/image/:id",      "destination": "/image.html"           },
    { "source": "/album/:id",      "destination": "/album.html"           },
    { "source": "/donate",         "destination": "/donate.html"          },
    { "source": "/expired",        "destination": "/expired.html"         },
    { "source": "/admin",          "destination": "/admin/index.html"     },
    { "source": "/admin/login",    "destination": "/admin/login.html"     },
    { "source": "/admin/images",   "destination": "/admin/images.html"    },
    { "source": "/admin/albums",   "destination": "/admin/albums.html"    },
    { "source": "/admin/users",    "destination": "/admin/users.html"     },
    { "source": "/admin/reports",  "destination": "/admin/reports.html"   },
    { "source": "/admin/settings", "destination": "/admin/settings.html"  }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*"             },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type"  }
      ]
    }
  ]
}
